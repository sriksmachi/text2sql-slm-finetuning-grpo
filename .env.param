AZURE_OPENAI_ENDPOINT=https://<your-resource-name>-<region>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=<your-deployment-name>
